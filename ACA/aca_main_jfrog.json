          "accountKey": "[listKeys(resourceId(variables('storageAccountSubscriptionId'), variables('storageAccountResourceGroupName'), 'Microsoft.Storage/storageAccounts', variables('effectiveStorageAccountName')), '2023-01-01').keys[0].value]",
