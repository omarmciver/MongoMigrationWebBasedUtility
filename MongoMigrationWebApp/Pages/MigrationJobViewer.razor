        }
    }

    private async Task DecreaseInsertionWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentInsertionWorkers ?? 0) > 1)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentInsertionWorkers ?? 0) - 1;
            JobManager.AdjustInsertionWorkers(newCount, CurrentlyLoadedMigrationJob);
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool NoOtherActiveJobs()
    {        

        string activeJob = JobManager?.GetRunningJobId() ?? string.Empty;
        if (activeJob != string.Empty && activeJob != JobId)
        {
            var job = MigrationJobContext.GetMigrationJob(activeJob);
            if (job != null && !job.IsCancelled && !job.IsCompleted)
                return false;
            else
                return true;
        }
        else
            return true;
    }

    private  bool  IsPauseEnabled()
    {
        return CurrentlyLoadedMigrationJob != null && !CurrentlyLoadedMigrationJob.IsCancelled && !CurrentlyLoadedMigrationJob.IsCompleted && IsJobRunning() && NoOtherActiveJobs();
    }


    private bool IsResumeEnabled()
    {
        return CurrentlyLoadedMigrationJob != null && !CurrentlyLoadedMigrationJob.IsCompleted && !IsJobRunning() && !IsPauseCooldownActive();
    }

    private bool CanAutoStart()
    {
        
        if (IsResumeEnabled() && NoOtherActiveJobs() && CurrentlyLoadedMigrationJob != null && CurrentlyLoadedMigrationJob.IsStarted &&
            !string.IsNullOrEmpty(MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id]) && 
            !string.IsNullOrEmpty(MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id]) &&
            CurrentlyLoadedMigrationJob.MigrationUnitBasics != null && CurrentlyLoadedMigrationJob.MigrationUnitBasics.Count > 0)
        {
            return true;
        }
        return false;
    }

    private void StartPauseCooldown()
    {
        _pauseCooldownUntil = DateTime.UtcNow.AddSeconds(10);
        _pauseCooldownTimer?.Dispose();
        _pauseCooldownTimer = new Timer(async _ =>
        {
            if (_pauseCooldownUntil.HasValue && DateTime.UtcNow >= _pauseCooldownUntil.Value)
            {
                _pauseCooldownUntil = null;
                _pauseCooldownTimer?.Dispose();
                _pauseCooldownTimer = null;
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private bool IsPauseCooldownActive()
    {
        return _pauseCooldownUntil.HasValue && DateTime.UtcNow < _pauseCooldownUntil.Value;
    }

    private int GetPauseCooldownSecondsRemaining()
    {
        if (!_pauseCooldownUntil.HasValue) return 0;
        return Math.Max(0, (int)Math.Ceiling((_pauseCooldownUntil.Value - DateTime.UtcNow).TotalSeconds));
    }

    private void StartFlipCooldown(int seconds, string targetLabel)
    {
        _flipCooldownUntil = DateTime.UtcNow.AddSeconds(seconds);
        _flipCooldownTargetLabel = targetLabel ?? string.Empty;
        _flipCooldownTimer?.Dispose();
        _flipCooldownTimer = new Timer(async _ =>
        {
            if (_flipCooldownUntil.HasValue && DateTime.UtcNow >= _flipCooldownUntil.Value)
            {
                _flipCooldownUntil = null;
                _flipCooldownTargetLabel = string.Empty;
                _flipCooldownTimer?.Dispose();
                _flipCooldownTimer = null;
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private bool IsFlipCooldownActive()
        => _flipCooldownUntil.HasValue && DateTime.UtcNow < _flipCooldownUntil.Value;

    private int GetFlipCooldownSecondsRemaining()
    {
        if (!_flipCooldownUntil.HasValue) return 0;
        return Math.Max(0, (int)Math.Ceiling((_flipCooldownUntil.Value - DateTime.UtcNow).TotalSeconds));
    }

    // Poll-wait for the change-stream processor's outer loop to exit after a graceful
    // auto-close was requested. Returns when IsChangeStreamProcessorRunning flips false
    // or when the timeout elapses. Deliberately a tight 500ms tick so flip UI feels
    // responsive once the in-flight batch ends.
    //
    // Timeout is derived from config: ChangeStreamBatchDuration (max per-batch duration,
    // default 120s) + a 60s buffer for post-batch unwind (Task.WhenAll, drain logs, the
    // 5s inter-batch sleep that may run if the safe-point check just missed, and the
    // finally that clears IsChangeStreamProcessorRunning). If config can't be loaded
    // we fall back to 3 min, which matches the historical conservative default.
    private async Task WaitForChangeStreamProcessorExitAsync()
    {
        int batchDurationSec = 120;
        try
        {
            var cfg = new OnlineMongoMigrationProcessor.MigrationSettings();
            cfg.Load();
            if (cfg.ChangeStreamBatchDuration > 0) batchDurationSec = cfg.ChangeStreamBatchDuration;
        }
        catch { }

        var timeout = TimeSpan.FromSeconds((batchDurationSec *2) + 60);
        var deadline = DateTime.UtcNow + timeout;
        while (DateTime.UtcNow < deadline && MigrationJobContext.IsChangeStreamProcessorRunning)
        {
            await Task.Delay(500);
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
        _pauseCooldownTimer?.Dispose();
        _pauseCooldownTimer = null;
        _flipCooldownTimer?.Dispose();
        _flipCooldownTimer = null;
    }

    // Response model for log count API
    public class LogCountResponse
    {
        public int count { get; set; }
    }
}

