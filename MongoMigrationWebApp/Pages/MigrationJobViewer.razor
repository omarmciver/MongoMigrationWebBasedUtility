    private async void OnCollectionsUpdated(List<MigrationUnit> migrationUnits)
    {

        if (migrationUnits != null && CurrentlyLoadedMigrationJob != null)
        {
            if (!Helper.ValidateNoTargetNamespaceClashes(migrationUnits, out var clashError))
            {
                _errorMessage = clashError;
                return;
            }

            // Get IDs for comparison
            var existingIds = CurrentlyLoadedMigrationJob.MigrationUnitBasics.Select(mu => mu.Id).ToHashSet();
            var newIds = migrationUnits.Select(mu => mu.Id).ToHashSet();

            //get ids that are no llonger present in newUnits
            var delList = CurrentlyLoadedMigrationJob.MigrationUnitBasics.FindAll(mu => !newIds.Contains(mu.Id));

            foreach (var tobDel in delList)
            {
                tobDel.ParentJob = CurrentlyLoadedMigrationJob;
                tobDel.Remove();
                // Centralized purge clears cache, mutate lock, persisted file, and active
                // change-stream processor state so a re-add of the same namespace starts clean.
                MigrationJobContext.PurgeMigrationUnit(CurrentlyLoadedMigrationJob.Id, tobDel.Id);
            }

            foreach (var mu in migrationUnits)
            {
                mu.ParentJob = CurrentlyLoadedMigrationJob;                
            }

            // Add new units that don’t exist in existingUnits
            // foreach (var mu in migrationUnits)
            // {
            //     if (!CurrentlyLoadedMigrationJob.MigrationUnitBasics.Any(x => x.DatabaseName == mu.DatabaseName && x.CollectionName == mu.CollectionName))
            //     {
            //         MigrationJobContext.SaveMigrationUnit(mu,false);
            //         //CurrentlyLoadedMigrationJob.MigrationUnitBasics.Add(mu.GetBasic());
            //         Helper.AddMigrationUnit(mu, CurrentlyLoadedMigrationJob);
            //     }
            // }
            if (!Helper.AddMigrationUnits(migrationUnits, CurrentlyLoadedMigrationJob))
            {
                _errorMessage = "Target namespace clash detected. Multiple source collections cannot map to the same target collection.";
                return;
            }

            CurrentlyLoadedMigrationJob.NameSpaces = Helper.BuildNamespaceConfigFromMigrationUnits(migrationUnits);

            MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob);

            // Pagination cache invalidates only on count changes; a re-add (remove+add of the
            // same Id) keeps count identical, so the cache would otherwise keep the orphan basic
            // reference with its prior 100% state until the next timer tick. Drop it synchronously
            // so the immediate post-modal render reflects the fresh basics.
            _cachedFilteredAndPagedUnits = null;
            _lastMigrationUnitsCount = -1;

            Refresh(null);
        }
    }




    private async Task YesNoDialogSubmit(YesNoDialog.YesNoDialogResult result)
    {
        _yesNoDialogOpen = false;

        if (result.IsConfirmed)
        {     
            if (result.DiaLogType == YesNoDialog.Category.CutoverNot || result.DiaLogType == YesNoDialog.Category.CompleteNot)
            {
                MigrationJobContext.AddVerboseLog($"YesNoDialogSubmit {result.DiaLogType}");

                // Graceful drain: request change-stream auto-close (no cts.Cancel), wait
                // for the in-flight batch/round to complete and the processor's outer loop
                // to exit, then mark the job terminal. We deliberately do NOT call
                // StopMigration here — that path is abrupt (cts.Cancel) and kills the
                // in-flight Task.WhenAll. PendingAction is persisted so a mid-drain app
                // restart can resume the cutover.
                if (CurrentlyLoadedMigrationJob != null)
                {
                    CurrentlyLoadedMigrationJob.PendingAction = OnlineMongoMigrationProcessor.Models.PendingChangeStreamAction.Cutover;
                    MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob);
                }
                MigrationJobContext.RequestChangeStreamAutoClose("UI: Cut Over");
                await InvokeAsync(StateHasChanged);

                try
                {
                    await WaitForChangeStreamProcessorExitAsync();
                    MigrationJobContext.ResetChangeStreamAutoClose();

                    if (CurrentlyLoadedMigrationJob != null)
                    {
                        CurrentlyLoadedMigrationJob.IsCancelled = true;
                        CurrentlyLoadedMigrationJob.IsCompleted = true;
                        CurrentlyLoadedMigrationJob.PendingAction = OnlineMongoMigrationProcessor.Models.PendingChangeStreamAction.None;
                        MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob);
                    }
                    _refreshTimer = null;
                }
                finally
                {
                    await InvokeAsync(StateHasChanged);
                }
                return;
            }
            else if (result.DiaLogType == YesNoDialog.Category.SyncBackNot)
            {
                if (CurrentlyLoadedMigrationJob != null)
                {
                    // Graceful flip (forward -> sync-back): request change-stream auto-close
                    // (no cts.Cancel), wait for the in-flight forward batch to complete and
                    // the processor's outer loop to exit, then open the sync-back cursor.
                    // The switch-over time captured AFTER the wait is the actual moment
                    // between cursors and is used as the new SyncBackChangeStreamStartedOn.
                    // PendingAction is persisted so a mid-drain app restart can resume the
                    // flip via JobManager auto-resume. We do NOT call StopMigration here —
                    // SyncBackToSource calls it internally once the worker is already idle.
                    var job = CurrentlyLoadedMigrationJob;
                    job.PendingAction = OnlineMongoMigrationProcessor.Models.PendingChangeStreamAction.SyncBackEnabled;
                    MigrationJobContext.SaveMigrationJob(job);
                    MigrationJobContext.RequestChangeStreamAutoClose("UI: Sync Back");
                    await InvokeAsync(StateHasChanged);

                    await WaitForChangeStreamProcessorExitAsync();
                    MigrationJobContext.ResetChangeStreamAutoClose();

                    var switchOverAt = DateTime.UtcNow;
                    ChangeStreamTransitionHelper.ResetSyncBackChangeStreamForReEnable(null, job, switchOverAt);

                    // 30s safety buffer after drain to let any Atlas-side cursor state
                    // for the closed forward cursor settle before the reverse opens.
                    StartFlipCooldown(30, "sync-back");
                    await InvokeAsync(StateHasChanged);

                    _ = Task.Run(async () =>
                    {
                        await Task.Delay(TimeSpan.FromSeconds(30));
                        await JobManager.SyncBackToSource(MigrationJobContext.SourceConnectionString[MigrationJobContext.CurrentlyActiveJob.Id], MigrationJobContext.TargetConnectionString[MigrationJobContext.CurrentlyActiveJob.Id], MigrationJobContext.CurrentlyActiveJob);

                        // The Refresh timer disposed itself when the previous worker's log
                        // bucket flipped to backup-file mode. Re-arm it now that a new worker
                        // is running so the UI keeps streaming sync-back logs without F5.
                        await InvokeAsync(StartAutoRefresh);
                    });
                }
                return;
            }
            else if (result.DiaLogType == YesNoDialog.Category.RestartForwardCSNot)
            {
                MigrationJobContext.AddVerboseLog($"YesNoDialogSubmit {result.DiaLogType}");
                if (CurrentlyLoadedMigrationJob != null)
                {
                    var sourceCs = MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty;
                    var targetCs = MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty;
                    var job = CurrentlyLoadedMigrationJob;

                    // Graceful flip (sync-back -> forward): request change-stream auto-close
                    // (no cts.Cancel), wait for the in-flight sync-back batch to complete
                    // and the processor's outer loop to exit, then open the forward cursor.
                    // switchOverAt captured AFTER the wait drives the new ChangeStreamStartedOn.
                    // PendingAction is persisted so a mid-drain app restart can resume the
                    // flip via JobManager auto-resume. StartMigration internally calls
                    // StopMigration once the worker is already idle.
                    job.PendingAction = OnlineMongoMigrationProcessor.Models.PendingChangeStreamAction.ForwardSyncEnabled;
                    MigrationJobContext.SaveMigrationJob(job);
                    MigrationJobContext.RequestChangeStreamAutoClose("UI: Restart Forward Sync");
                    await InvokeAsync(StateHasChanged);

                    await WaitForChangeStreamProcessorExitAsync();
                    MigrationJobContext.ResetChangeStreamAutoClose();

                    var switchOverAt = DateTime.UtcNow;
                    ChangeStreamTransitionHelper.ResetForwardChangeStreamForReEnable(null, job, switchOverAt);
                    job.ProcessingSyncBack = false;
                    MigrationJobContext.SaveMigrationJob(job);

                    StartFlipCooldown(30, "forward sync");
                    await InvokeAsync(StateHasChanged);

                    _ = Task.Run(async () =>
                    {
                        await Task.Delay(TimeSpan.FromSeconds(30));
                        await JobManager.StartMigration(
                            job, sourceCs, targetCs, job.NameSpaces ?? string.Empty, job.JobType, Helper.IsOnline(job));

                        // The Refresh timer disposed itself when the previous worker's log
                        // bucket flipped to backup-file mode. Re-arm it now that a new worker
                        // is running so the UI keeps streaming forward-sync logs without F5.
                        await InvokeAsync(StartAutoRefresh);
                    });
                }
                return;
            }
            else if( result.DiaLogType == YesNoDialog.Category.RunComparisonNot)
            {
                if (CurrentlyLoadedMigrationJob != null)
                {
                    CurrentlyLoadedMigrationJob.RunComparison = true;
                }
                if (MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob))
                    return;
            }

        }
        else
        {
            if (result.DiaLogType == YesNoDialog.Category.RunComparisonNot)
            {
                if (CurrentlyLoadedMigrationJob != null)
                {
                    CurrentlyLoadedMigrationJob.RunComparison = false;
                }
                if (MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob))
                    return;
            }
        }
    }

    private async Task PauseJobImmediate()
    {
        _errorMessage = string.Empty;
        try
        {
            // Start cooldown immediately so the UI shows "Resume in Xs" right away.
            StartPauseCooldown();
            await InvokeAsync(StateHasChanged);

            // Run StopMigration on a background thread so the Blazor circuit isn't blocked
            // by the 10-second worker await in StopCoordinatedProcessing.
            await Task.Run(() => JobManager.StopMigration());

            var job = CurrentlyLoadedMigrationJob;
            if (job != null)
            {
                MigrationJobContext.SaveMigrationJob(job);
            }

            _refreshTimer?.Dispose();
            _refreshTimer = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Pause failed: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private void PauseJobControlled()
    {
        _errorMessage = string.Empty;
        MigrationJobContext.RequestControlledPause("UI Button Click");

        MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob);
        StartPauseCooldown();
    }

    private async Task IncreaseDumpWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentDumpWorkers ?? 0) < 16)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentDumpWorkers ?? 0) + 1;
            JobManager.AdjustDumpWorkers(newCount, CurrentlyLoadedMigrationJob);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DecreaseDumpWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentDumpWorkers ?? 0) > 0)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentDumpWorkers ?? 0) - 1;
            JobManager.AdjustDumpWorkers(newCount, CurrentlyLoadedMigrationJob);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task IncreaseRestoreWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentRestoreWorkers ?? 0) < 16)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentRestoreWorkers ?? 0) + 1;
            JobManager.AdjustRestoreWorkers(newCount, CurrentlyLoadedMigrationJob);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DecreaseRestoreWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentRestoreWorkers ?? 0) > 0)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentRestoreWorkers ?? 0) - 1;
            JobManager.AdjustRestoreWorkers(newCount, CurrentlyLoadedMigrationJob);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task IncreaseInsertionWorkers()
    {
        if (CurrentlyLoadedMigrationJob != null && (CurrentlyLoadedMigrationJob.CurrentInsertionWorkers ?? 0) < 16)
        {
            int newCount = (CurrentlyLoadedMigrationJob.CurrentInsertionWorkers ?? 0) + 1;
            JobManager.AdjustInsertionWorkers(newCount, CurrentlyLoadedMigrationJob);
