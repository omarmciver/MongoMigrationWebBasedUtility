    private async Task<bool> OnMigrationDetailsPopUpSubmit(MigrationJob? job, string sourceConnectionString, string targetConnectionString)
    {
        _migrationDetailsPopUpOpen = false;
        await Task.Delay(100);

        if (job == null || CurrentlyLoadedMigrationJob == null)
        {
            await InvokeAsync(StateHasChanged);
            return false;
        }

        bool isServerToCollectionTransition =
            CurrentlyLoadedMigrationJob.ChangeStreamLevel == OnlineMongoMigrationProcessor.Models.ChangeStreamLevel.Server &&
            job.ChangeStreamLevel == OnlineMongoMigrationProcessor.Models.ChangeStreamLevel.Collection;

        bool isCollectionToServerTransition =
            CurrentlyLoadedMigrationJob.ChangeStreamLevel == OnlineMongoMigrationProcessor.Models.ChangeStreamLevel.Collection &&
            job.ChangeStreamLevel == OnlineMongoMigrationProcessor.Models.ChangeStreamLevel.Server;

        ApplySubmittedJobSettings(CurrentlyLoadedMigrationJob, job);

        if (isServerToCollectionTransition)
        {
            // Reset change stream for every collection (equivalent to ResetCS per unit)
            // and clear server-level state so collection-level processing restarts cleanly.
            OnlineMongoMigrationProcessor.Helpers.ChangeStreamTransitionHelper
                .TransitionServerToCollectionResumeCheckpoints(
                    null,
                    CurrentlyLoadedMigrationJob,
                    CurrentlyLoadedMigrationJob.ProcessingSyncBack);
        }
        else if (isCollectionToServerTransition)
        {
            // No state reset needed here - TryTransitionCollectionToServerResumeCheckpoint
            // performs the actual bootstrap when the worker starts. Just record the action
            // so the bootstrap log accurately reflects what triggered it.
            CurrentlyLoadedMigrationJob.PendingAction = OnlineMongoMigrationProcessor.Models.PendingChangeStreamAction.CollectionToServer;
        }

        if (!string.IsNullOrEmpty(sourceConnectionString))
            MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id] = sourceConnectionString;

        if (!string.IsNullOrEmpty(targetConnectionString))
            MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id] = targetConnectionString;

        // Validate that both connection strings are available before starting
        var storedSourceConnStr = MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id];
        var storedTargetConnStr = MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id];

        if (string.IsNullOrWhiteSpace(storedSourceConnStr) || string.IsNullOrWhiteSpace(storedTargetConnStr))
        {
            _errorMessage = "Both source and target connection strings are required. Please provide them using 'Resume Job' → 'With Updated Connection Strings' and try again.";
            await InvokeAsync(StateHasChanged);
            return false;
        }

        // Validate that collections are configured
        if (CurrentlyLoadedMigrationJob.MigrationUnitBasics == null || CurrentlyLoadedMigrationJob.MigrationUnitBasics.Count == 0)
        {
            _errorMessage = "No collections configured. Please add collections to start migrating.";
            await InvokeAsync(StateHasChanged);
            return false;
        }

        // CurrentlyLoadedMigrationJob.CurrentlyActive = true;
        CurrentlyLoadedMigrationJob.IsCancelled = false;

        if (!CurrentlyLoadedMigrationJob.StartedOn.HasValue)
            CurrentlyLoadedMigrationJob.StartedOn = DateTime.UtcNow;

        CurrentlyLoadedMigrationJob.IsStarted = true;

        //var jobList = JobManager.GetJobList();
        MigrationJobContext.SaveMigrationJob(CurrentlyLoadedMigrationJob);
        MigrationJobContext.SaveJobList();


        // Fire-and-forget: Run the long task on a separate thread without blocking
        _ = Task.Run(async () =>
        {
            // JobManager.DisposeLogs();

            if (CurrentlyLoadedMigrationJob.ProcessingSyncBack && !CurrentlyLoadedMigrationJob.IsSimulatedRun)
            {
                await JobManager.SyncBackToSource(
                    MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty,
                    MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty, 
                    CurrentlyLoadedMigrationJob);
            }
            else
            {
                await JobManager.StartMigration(CurrentlyLoadedMigrationJob,
                    MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty,
                    MigrationJobContext.TargetConnectionString[CurrentlyLoadedMigrationJob.Id] ?? string.Empty,
                    CurrentlyLoadedMigrationJob.NameSpaces ?? string.Empty,
                    CurrentlyLoadedMigrationJob.JobType,
                    Helper.IsOnline(CurrentlyLoadedMigrationJob));
            }
        });

        StartAutoRefresh();
        return true;
    }

    private static void ApplySubmittedJobSettings(MigrationJob current, MigrationJob submitted)
    {
        current.Name = submitted.Name;
        current.CDCMode = submitted.CDCMode;
        current.NameSpaces = submitted.NameSpaces;
        current.JobType = submitted.JobType;
        current.IsSimulatedRun = submitted.IsSimulatedRun;
        current.EnableParallelProcessing = submitted.EnableParallelProcessing;
        current.CurrentDumpWorkers = submitted.CurrentDumpWorkers;
        current.CurrentRestoreWorkers = submitted.CurrentRestoreWorkers;
        current.CurrentInsertionWorkers = submitted.CurrentInsertionWorkers;
        current.ParallelThreads = submitted.ParallelThreads;
        current.SyncBackEnabled = submitted.SyncBackEnabled;
        current.ChangeStreamMode = submitted.ChangeStreamMode;
        current.ChangeStreamLevel = submitted.ChangeStreamLevel;
        current.LogLevel = submitted.LogLevel;
    }

    private void RunComparison()
    {
        _errorMessage = string.Empty;

        // Check if SourceConnectionString is blank
        if (string.IsNullOrWhiteSpace(MigrationJobContext.SourceConnectionString[CurrentlyLoadedMigrationJob.Id]))
        {
            _errorMessage = "Source connection string is not available. Please use 'Resume Job' → 'With Updated Connection Strings' to provide connection details, then pause the job before running comparison.";
            return;
        }

        if (IsResumeEnabled())
        {
            _yesNoDiaLogType=YesNoDialog.Category.RunComparisonNot;
            _message = "Comparing collections using random sampling may take some time. This process will block the migration and could cause delays. Please confirm if you want to continue with the comparison. You will need to resume the job to continue.";
            _yesNoDialogOpen = true;

        }
        else
        {
            _errorMessage = "Please pause the job before you run the comparison.";
        }
    }

